{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel.local/contracts/health.schema.json",
  "title": "kernel HealthStatus",
  "type": "object",
  "required": [
    "name",
    "status",
    "message",
    "checked_at",
    "latency_ms",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "unhealthy"
      ]
    },
    "message": {
      "type": "string"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
