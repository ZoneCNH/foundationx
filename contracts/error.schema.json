{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel.local/contracts/error.schema.json",
  "title": "kernel Error",
  "type": "object",
  "required": [
    "kind",
    "message",
    "retryable"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "config",
        "validation",
        "connection",
        "unavailable",
        "timeout",
        "auth",
        "conflict",
        "rate_limit",
        "canceled",
        "not_found",
        "already_exists",
        "internal"
      ]
    },
    "code": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ]
    },
    "op": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "retryable": {
      "type": "boolean"
    }
  }
}
