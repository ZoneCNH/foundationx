# EditorConfig — 统一编辑器格式规范
# https://editorconfig.org

root = true

# ========== 通用 ==========
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ========== Go ==========
[*.go]
indent_style = tab
indent_size = 4

# ========== YAML ==========
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ========== JSON ==========
[*.json]
indent_style = space
indent_size = 2

# ========== Markdown ==========
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ========== Shell ==========
[*.sh]
indent_style = space
indent_size = 2

# ========== Makefile ==========
[Makefile]
indent_style = tab

# ========== Toml ==========
[*.toml]
indent_style = space
indent_size = 2

# ========== Go Module ==========
[go.mod]
indent_style = tab

[go.sum]
insert_final_newline = false
